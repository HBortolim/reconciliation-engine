# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=reconciliation
POSTGRES_USER=recon_user
POSTGRES_PASSWORD=recon_secret_dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MinIO (S3-compatible)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=reconciliation-files
MINIO_USE_SSL=false

# API
API_PORT=8080
API_JWT_SECRET=dev-jwt-secret-change-in-production
API_CORS_ORIGINS=http://localhost:3000

# Worker
WORKER_CONCURRENCY=4
WORKER_REDIS_STREAM=reconciliation-jobs

# Dashboard
VITE_API_URL=http://localhost:8080

# Logging
LOG_LEVEL=debug
